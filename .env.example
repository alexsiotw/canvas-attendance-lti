# LTI Configuration
LTI_KEY=attendance-lti-key
LTI_SECRET=attendance-lti-secret

# Canvas API
CANVAS_API_URL=https://canvas.instructure.com/api/v1
CANVAS_API_TOKEN=your_canvas_api_token_here

# Database (Supabase PostgreSQL - get free at supabase.com)
